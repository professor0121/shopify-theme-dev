{%- comment -%}
  Cart Fallback Page Section.
{%- endcomment -%}
<div class="container" style="margin-top: 6rem; margin-bottom: 8rem;">
  <h1 class="gradient-text text-center" style="margin-bottom: 5rem;">Your Cart</h1>
  
  {%- if cart.item_count > 0 -%}
    <form action="{{ routes.cart_url }}" method="post" class="cart-form">
      
      <div class="cart-items">
        {%- for item in cart.items -%}
          <div class="cart-item" style="border-bottom: 1px solid var(--color-border); padding: 3rem 0; display: flex; gap: 3rem; align-items: center;">
            <div style="width: 120px; height: 120px; border-radius: 8px; border: 1px solid var(--color-border); overflow: hidden; background: rgba(255,255,255,0.01);">
              {%- if item.image -%}
                {{ item.image | image_url: width: 240 | image_tag: loading: 'lazy', alt: item.title, style: 'width: 100%; height: 100%; object-fit: cover;' }}
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
            
            <div style="flex-grow: 1;">
              <h3 style="margin-bottom: 0.5rem;"><a href="{{ item.url }}">{{ item.product.title | escape }}</a></h3>
              {%- if item.product.has_only_default_variant == false -%}
                <p class="text-muted" style="font-size: 1.3rem; margin-top: 0;">{{ item.variant.title }}</p>
              {%- endif -%}
              <p style="font-weight: 700; font-size: 1.6rem; margin-bottom: 1rem;">{{ item.price | money }}</p>
            </div>
            
            <div style="display: flex; align-items: center; gap: 2rem;">
              <quantity-input class="quantity">
                <button class="quantity__button" name="minus" type="button">-</button>
                <input class="quantity__input" type="number" name="updates[]" value="{{ item.quantity }}" min="0" data-key="{{ item.key }}" aria-label="Quantity for {{ item.product.title | escape }}">
                <button class="quantity__button" name="plus" type="button">+</button>
              </quantity-input>
              
              <a href="{{ item.url_to_remove }}" style="font-size: 1.4rem; text-decoration: underline;" class="text-muted">Remove</a>
            </div>
          </div>
        {%- endfor -%}
      </div>

      <div style="text-align: right; margin-top: 5rem;">
        <h2 style="font-size: 2.8rem; margin-bottom: 1rem;">Subtotal: {{ cart.total_price | money }}</h2>
        <p class="text-muted" style="font-size: 1.3rem; margin-bottom: 3rem;">Taxes and shipping calculated at checkout</p>
        
        <div style="display: flex; justify-content: flex-end; gap: 2rem;">
          <button type="submit" name="update" class="button button--secondary">Update Quantities</button>
          <button type="submit" name="checkout" class="button button--primary">Check Out</button>
        </div>
      </div>
      
    </form>
  {%- else -%}
    <div class="text-center" style="padding: 6rem 0;">
      <p class="text-muted" style="font-size: 1.8rem; margin-bottom: 3rem;">Your cart is currently empty.</p>
      <a href="{{ routes.all_products_collection_url }}" class="button button--primary">Continue Shopping</a>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Cart Page",
  "settings": []
}
{% endschema %}
