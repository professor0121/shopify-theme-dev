{%- comment -%}
  Webflow-compatible Main Product Details Section.
{%- endcomment -%}
<div class="top-section pd-bottom-130px pd-top-40px">
  <div class="container-default w-container">
    
    <!-- Breadcrumbs -->
    <div class="flex align-center mg-bottom-64px" data-w-id="57ad05f3-b37f-6519-1c1c-47c3caef8903" style="opacity:1">
      <a class="product-category-link font-size-14px-mbp" href="{{ routes.all_products_collection_url }}">Products</a>
      <div class="text-400 color-neutral-400 mg-sides-18px">/</div>
      {%- if product.collections.size > 0 -%}
        <a class="product-category-link font-size-14px-mbp" href="{{ product.collections.first.url }}">{{ product.collections.first.title | escape }}</a>
        <div class="text-400 color-neutral-400 mg-sides-18px">/</div>
      {%- endif -%}
      <div class="product-category-link current-product font-size-14px-mbp">{{ product.title | escape }}</div>
    </div>

    <!-- Product Grid layout -->
    <div class="grid-2-columns _1-11fr---1fr gap-row-80px">
      
      <!-- Gallery Column -->
      <div class="grid-4-columns gap-column-24px" data-w-id="b2454874-6751-3403-c61d-0861abeec098" id="w-node-b2454874-6751-3403-c61d-0861abeec098-641e91f4" style="opacity:1">
        {%- if product.media.size > 0 -%}
          <!-- First Media (Featured) -->
          <a class="sibling-link-item w-inline-block w-lightbox" id="w-node-_5ebcd739-1f70-e20c-d9e2-09bc149c9c0d-641e91f4" href="#">
            {{ product.featured_media | image_url: width: 800 | image_tag: alt: product.title, class: 'border-radius-56px width-100', loading: 'eager', width: product.featured_media.width, height: product.featured_media.height }}
          </a>
          
          <!-- Loop remaining Media (up to 4 thumbnails) -->
          {%- for media in product.media offset: 1 limit: 4 -%}
            <a class="sibling-link-item w-inline-block w-lightbox" href="#">
              {{ media | image_url: width: 300 | image_tag: alt: product.title, class: 'border-radius-24px border-radius-12px-mbl', loading: 'eager', width: media.width, height: media.height }}
            </a>
          {%- endfor -%}
        {%- else -%}
          <!-- Fallback mockup images if no product media is present -->
          <a class="sibling-link-item w-inline-block w-lightbox" href="#">
            <img alt="Wireless Mouse" class="border-radius-56px width-100" src="https://cdn.prod.website-files.com/630784cc70ef0552de1e91e2/6309270f2bf613293da1ae56_wireless-mouse-product-image-large-shopper-webflow-ecommerce-template.jpg" width="800" height="800" />
          </a>
        {%- endif -%}
      </div>

      <!-- Purchasing Details Column -->
      <div class="inner-container _578px _100-tablet" data-w-id="a8792659-cbfa-040c-d728-ba1acdabaee0" id="w-node-a8792659-cbfa-040c-d728-ba1acdabaee0-641e91f4" style="opacity:1">
        <h1 class="display-2 mg-bottom-8px">{{ product.title | escape }}</h1>
        
        <!-- Short description -->
        <p class="mg-bottom-24px">{{ product.description | strip_html | truncatewords: 30 }}</p>
        
        <!-- Price system -->
        <div class="mg-bottom-48px">
          <div class="flex gap-28px children-wrap">
            <div class="text-400 medium color-neutral-800" id="ProductPrice-{{ section.id }}">
              {{ product.selected_or_first_available_variant.price | money }}
            </div>
            {%- if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price -%}
              <div class="text-400 text-strikethrough" id="ComparePrice-{{ section.id }}">
                {{ product.selected_or_first_available_variant.compare_at_price | money }}
              </div>
            {%- endif -%}
          </div>
        </div>

        <!-- Add to Cart / Buy Now forms -->
        <div class="mg-bottom-40px">
          {%- form 'product', product, class: 'mg-bottom-0' -%}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
            
            <div class="flex gap-column-24px mg-bottom-24px">
              <!-- Quantity Selector -->
              <input class="input product-quantity-input" min="1" name="quantity" type="number" value="1" style="width: 100px; text-align: center;" />
              
              <!-- Variant dropdown -->
              {%- unless product.has_only_default_variant -%}
                <div class="width-100">
                  <select name="id" id="Variant-Selector-{{ section.id }}" class="input color-neutral-600 w-select" onchange="handleVariantChange(this)" style="display: block; width: 100%;">
                    {%- for variant in product.variants -%}
                      <option value="{{ variant.id }}" {% if variant == product.selected_or_first_available_variant %}selected="selected"{% endif %} {% unless variant.available %}disabled="disabled"{% endunless %}>
                        {{ variant.title }} - {{ variant.price | money }}
                      </option>
                    {%- endfor -%}
                  </select>
                </div>
              {%- endunless -%}
            </div>

            <div class="grid-2-columns">
              <!-- Submit button -->
              <input
                type="submit"
                value="{% if product.selected_or_first_available_variant.available %}Add to Cart{% else %}Sold Out{% endif %}"
                class="btn-primary"
                style="width: 100%; border: none; cursor: pointer;"
                {% unless product.selected_or_first_available_variant.available %}disabled="disabled"{% endunless %}
              />
              
              <!-- Buy Now -->
              <button type="submit" name="checkout" class="btn-secondary" style="width: 100%;">Shop now</button>
            </div>
          {%- endform -%}
        </div>

        <!-- Details List -->
        <div>
          {%- if section.settings.show_brand and product.vendor != blank -%}
            <div class="grid-2-columns product-page-details">
              <div class="text-bold">Product Brand</div>
              <div>{{ product.vendor | escape }}</div>
            </div>
            <div class="divider _24px bg-neutral-300"></div>
          {%- endif -%}
          
          {%- if product.metafields.my_fields.size != blank -%}
            <div class="grid-2-columns product-page-details">
              <div class="text-bold">Product size</div>
              <div>{{ product.metafields.my_fields.size }}</div>
            </div>
            <div class="divider _24px bg-neutral-300"></div>
          {%- endif -%}
          
          {%- if product.metafields.my_fields.weight != blank -%}
            <div class="grid-2-columns product-page-details">
              <div class="text-bold">Product weight</div>
              <div>{{ product.metafields.my_fields.weight }}</div>
            </div>
            <div class="divider _24px bg-neutral-300"></div>
          {%- endif -%}
        </div>

        <div class="divider mg-bottom-32px bg-neutral-300"></div>

        <!-- Accepted Payment Methods -->
        <div class="accepted-payment-methods-container">
          <div class="line-height-1-333em color-neutral-800 mg-right-16px">Accepted payment methods</div>
          <div class="grid-3-columns _3-col-mbp gap-14px">
            <img alt="PayPal" loading="eager" src="https://cdn.prod.website-files.com/630784cc70ef0552ae1e91dc/631284368bf0c1656fb8ce10_paypal-payment-method-shopper-webflow-ecommerce-template.svg" width="40" height="25" />
            <img alt="Stripe" loading="eager" src="https://cdn.prod.website-files.com/630784cc70ef0552ae1e91dc/6312843646c11aee5a21b7d2_stripe-payment-method-shopper-webflow-ecommerce-template.svg" width="40" height="25" />
            <img alt="Mastercard" loading="eager" src="https://cdn.prod.website-files.com/630784cc70ef0552ae1e91dc/631284367bab4a4d4f245780_mastercard-payment-method-shopper-webflow-ecommerce-template.svg" width="40" height="25" />
          </div>
        </div>

      </div>

    </div>
  </div>
</div>

<script>
  // Simple JS to update price when variant selector is changed
  const pdpVariants = {{ product.variants | json }};
  
  function handleVariantChange(selectElement) {
    const selectedId = selectElement.value;
    const form = selectElement.closest('form');
    if (!form) return;
    
    // Find variant details
    const variant = pdpVariants.find(v => v.id == selectedId);
    if (!variant) return;
    
    // Update hidden input ID
    const idInput = form.querySelector('input[name="id"]');
    if (idInput) idInput.value = variant.id;
    
    // Update price fields
    const priceText = document.getElementById('ProductPrice-{{ section.id }}');
    const comparePriceText = document.getElementById('ComparePrice-{{ section.id }}');
    
    if (priceText) {
      priceText.innerText = Shopify.formatMoney ? Shopify.formatMoney(variant.price) : '$' + (variant.price / 100).toFixed(2);
    }
    
    if (comparePriceText) {
      if (variant.compare_at_price > variant.price) {
        comparePriceText.innerText = Shopify.formatMoney ? Shopify.formatMoney(variant.compare_at_price) : '$' + (variant.compare_at_price / 100).toFixed(2);
        comparePriceText.style.display = 'block';
      } else {
        comparePriceText.style.display = 'none';
      }
    }
    
    // Update submit button
    const submitBtn = form.querySelector('input[type="submit"]');
    if (submitBtn) {
      if (variant.available) {
        submitBtn.disabled = false;
        submitBtn.value = "Add to Cart";
      } else {
        submitBtn.disabled = true;
        submitBtn.value = "Sold Out";
      }
    }
  }
</script>

{% schema %}
{
  "name": "Webflow Product Details",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_brand",
      "label": "Show Brand (Vendor)",
      "default": true
    }
  ]
}
{% endschema %}
