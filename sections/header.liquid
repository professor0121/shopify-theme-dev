{%- comment -%}
  Webflow-compatible Header section.
{%- endcomment -%}
<div class="header-wrapper w-nav" data-animation="default" data-collapse="medium" data-duration="400" data-easing="ease" data-easing2="ease" role="banner">
  <div class="container-default w-container">
    <div class="header-content-wrapper">
      
      <!-- Left side Navigation Menu (Desktop) -->
      <div class="header-right-side hidden-on-tablet">
        <ul class="header-nav-menu-list" role="list">
          {%- assign has_about = false -%}
          {%- for link in section.settings.menu.links -%}
            {%- assign down_title = link.title | downcase -%}
            {%- if down_title contains 'about' -%}
              {%- assign has_about = true -%}
            {%- endif -%}
            {%- if link.links != blank -%}
              <li class="header-nav-list-item left">
                <div class="dropdown-wrapper w-dropdown" data-delay="0" data-hover="true">
                  <div class="dropdown-toggle w-dropdown-toggle">
                    <div>{{ link.title | escape }}</div>
                    <div class="line-rounded-icon dropdown-arrow"></div>
                  </div>
                  <nav class="dropdown-column-wrapper w-dropdown-list">
                    <div class="dropdown-pd pd-28px">
                      <div class="w-layout-grid grid-1-column dropdown-link-column">
                        {%- for childlink in link.links -%}
                          <a class="dropdown-link w-dropdown-link" href="{{ childlink.url }}">
                            {{ childlink.title | escape }}
                          </a>
                        {%- endfor -%}
                      </div>
                    </div>
                  </nav>
                </div>
              </li>
            {%- else -%}
              <li class="header-nav-list-item left">
                <a class="header-nav-link w-nav-link" href="{{ link.url }}">{{ link.title | escape }}</a>
              </li>
            {%- endif -%}
          {%- endfor -%}
          {%- unless has_about -%}
            <li class="header-nav-list-item left">
              <a class="header-nav-link w-nav-link" href="/pages/about">About</a>
            </li>
          {%- endunless -%}
        </ul>
      </div>

      <!-- Logo (Middle) -->
      <div class="header-middle">
        <a class="header-logo-link w-nav-brand" href="{{ routes.root_url }}">
          {%- if section.settings.logo != blank -%}
            {{ section.settings.logo | image_url: width: 250 | image_tag: alt: shop.name, style: 'max-height: 40px; width: auto;', width: section.settings.logo.width, height: section.settings.logo.height }}
          {%- else -%}
            <img alt="Commerce X Webflow Template - Logo" src="https://cdn.prod.website-files.com/630784cc70ef0552ae1e91dc/63334bd4541e515298dcb4bd_logo-commerce-webflow-ecommerce-template.svg" width="180" height="40" />
          {%- endif -%}
        </a>
      </div>

      <!-- Right side Actions (Mobile Menu + Cart) -->
      <div class="header-left-side">
        <!-- Navigation Menu for Mobile (Tablet and down) -->
        <nav class="header-nav-menu-wrapper w-nav-menu" role="navigation">
          <ul class="header-nav-menu-list" role="list">
            {%- assign has_about_mobile = false -%}
            {%- for link in section.settings.menu.links -%}
              {%- assign down_title = link.title | downcase -%}
              {%- if down_title contains 'about' -%}
                {%- assign has_about_mobile = true -%}
              {%- endif -%}
              {%- if link.links != blank -%}
                <li class="header-nav-list-item left show-in-tablet">
                  <div class="dropdown-wrapper w-dropdown" data-delay="0" data-hover="true">
                    <div class="dropdown-toggle w-dropdown-toggle">
                      <div>{{ link.title | escape }}</div>
                      <div class="line-rounded-icon dropdown-arrow"></div>
                    </div>
                    <nav class="dropdown-column-wrapper w-dropdown-list">
                      <div class="dropdown-pd pd-48px pd-24px-tablet">
                        <div class="w-layout-grid grid-1-column dropdown-link-column">
                          {%- for childlink in link.links -%}
                            <a class="dropdown-link w-dropdown-link" href="{{ childlink.url }}">
                              {{ childlink.title | escape }}
                            </a>
                          {%- endfor -%}
                        </div>
                      </div>
                    </nav>
                  </div>
                </li>
              {%- else -%}
                <li class="header-nav-list-item left show-in-tablet">
                  <a class="header-nav-link w-nav-link" href="{{ link.url }}">{{ link.title | escape }}</a>
                </li>
              {%- endif -%}
            {%- endfor -%}
            {%- unless has_about_mobile -%}
              <li class="header-nav-list-item left show-in-tablet">
                <a class="header-nav-link w-nav-link" href="/pages/about">About</a>
              </li>
            {%- endunless -%}
          </ul>
        </nav>

        <!-- Cart Button -->
        <div class="w-commerce-commercecartwrapper" data-node-type="commerce-cart-wrapper">
          <a aria-haspopup="dialog" aria-label="Open cart" class="w-commerce-commercecartopenlink cart-button w-inline-block" href="#" role="button" onclick="const drawer = document.querySelector('cart-drawer'); if (drawer) drawer.open(); return false;">
            <div class="w-commerce-commercecartopenlinkcount cart-quantity">{{ cart.item_count }}</div>
            <img alt="Cart" loading="eager" src="https://cdn.prod.website-files.com/630784cc70ef0552ae1e91dc/6307abe4c4e2be299db62add_cart-menu-icon-shopper-webflow-ecommerce-template.svg" width="24" height="24" />
          </a>
        </div>

        <!-- Mobile Hamburger Trigger -->
        <div class="hamburger-menu-wrapper w-nav-button" aria-label="menu" role="button" tabindex="0" aria-controls="w-nav-overlay-0" aria-haspopup="menu" aria-expanded="false">
          <div class="hamburger-menu-bar top"></div>
          <div class="hamburger-menu-bar bottom"></div>
        </div>

      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Webflow Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Custom Logo Image"
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Navigation Menu"
    }
  ]
}
{% endschema %}
