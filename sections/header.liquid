{%- comment -%}
  Header section.
{%- endcomment -%}
<div class="header-wrapper" id="shopify-section-header">
  <header class="header container">
    
    <!-- Mobile Navigation Toggle -->
    <button class="header__menu-toggle" type="button" aria-expanded="false" aria-controls="MobileMenu" aria-label="Toggle Navigation" onclick="toggleMobileMenu()">
      {% render 'icon-menu' %}
    </button>

    <!-- Site Logo / Name -->
    <div class="header__heading">
      <a href="{{ routes.root_url }}" class="header__heading-link">
        {%- if section.settings.logo != blank -%}
          {{ section.settings.logo | image_url: width: 250 | image_tag: alt: shop.name }}
        {%- else -%}
          <span class="gradient-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </div>

    <!-- Navigation Menu (Desktop) -->
    <nav class="header__inline-menu">
      <ul class="list-menu">
        {%- for link in section.settings.menu.links -%}
          <li>
            <a href="{{ link.url }}" class="header__menu-item {% if link.active %} header__menu-item--active{% endif %}">
              {{ link.title | escape }}
            </a>
          </li>
        {%- endfor -%}
      </ul>
    </nav>

    <!-- Header Actions (Search & Cart) -->
    <div class="header__icons">
      <a href="{{ routes.search_url }}" class="header__icon">
        {% render 'icon-search' %}
      </a>
      
      <button class="header__icon" id="cart-icon-bubble" type="button" onclick="const drawer = document.querySelector('cart-drawer'); if (drawer) drawer.open();" aria-label="Open cart drawer">
        {% render 'icon-cart' %}
        <div class="cart-count-bubble">
          <span aria-hidden="true">{{ cart.item_count }}</span>
          <span class="visually-hidden">{{ cart.item_count }} items in cart</span>
        </div>
      </button>
    </div>

  </header>
</div>

<!-- Mobile Navigation Drawer -->
<div id="MobileMenu" class="drawer" aria-hidden="true" style="justify-content: flex-start;">
  <div class="drawer__overlay" onclick="toggleMobileMenu()"></div>
  <div class="drawer__inner" style="transform: translateX(-100%); width: 300px; padding: 2.4rem;">
    <div class="drawer__header" style="padding: 0 0 2rem 0;">
      <h3 class="drawer__heading">Menu</h3>
      <button class="drawer__close" type="button" onclick="toggleMobileMenu()">
        {% render 'icon-close' %}
      </button>
    </div>
    <div class="drawer__content" style="padding: 0;">
      <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 2rem;">
        {%- for link in section.settings.menu.links -%}
          <li>
            <a href="{{ link.url }}" style="font-size: 1.8rem; font-weight: 600;">
              {{ link.title | escape }}
            </a>
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </div>
</div>

<script>
  function toggleMobileMenu() {
    const mobileMenu = document.getElementById('MobileMenu');
    if (!mobileMenu) return;
    const isExpanded = mobileMenu.getAttribute('aria-hidden') === 'false';
    
    mobileMenu.setAttribute('aria-hidden', isExpanded ? 'true' : 'false');
    const inner = mobileMenu.querySelector('.drawer__inner');
    if (inner) {
      inner.style.transform = isExpanded ? 'translateX(-100%)' : 'translateX(0)';
    }
  }
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Navigation Menu"
    }
  ]
}
{% endschema %}
