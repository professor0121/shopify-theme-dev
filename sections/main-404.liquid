{%- comment -%}
  404 Page Section.
{%- endcomment -%}
<div class="container text-center" style="padding: 12rem 0;">
  <h1 class="gradient-text" style="font-size: 10rem; font-weight: 900; margin-bottom: 2rem; line-height: 1;">404</h1>
  <h2 style="font-size: 2.8rem; margin-bottom: 2rem;">Page Not Found</h2>
  <p class="text-muted" style="max-width: 480px; margin: 0 auto 4rem auto; font-size: 1.6rem;">
    The page you are looking for does not exist, has been removed, or is temporarily unavailable.
  </p>
  <a href="{{ routes.root_url }}" class="button button--primary">
    Back to Home
  </a>
</div>

{% schema %}
{
  "name": "404 Error Page",
  "settings": []
}
{% endschema %}
