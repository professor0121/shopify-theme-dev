{%- liquid
  assign site_id = '630784cc70ef0552ae1e91dc'
  assign page_id = '63079bcb0ed8d214701f600c'
  
  if template.name == 'index'
    assign page_id = '63079bcb0ed8d214701f600c'
  elsif template.name == 'product'
    assign page_id = '630784cc70ef0514641e91f4'
  elsif template.name == 'collection'
    assign page_id = '63122f5ef4eb4a60ee66143b'
  elsif page.handle == 'about' or template.suffix == 'about'
    assign page_id = '630e5aad392166c7aaebb795'
  elsif page.handle == 'contact' or template.suffix == 'contact'
    assign page_id = '630e9281f78ec0f59e2161e9'
  endif
-%}
<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}" data-wf-site="{{ site_id }}" data-wf-page="{{ page_id }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_bg }}">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
    <link crossorigin="anonymous" href="https://cdn.prod.website-files.com" rel="preconnect">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% render 'meta-tags' %}

    <!-- Load Localized Webflow JS Mode Flag -->
    <script type="text/javascript">
      !function(o,c){var n=c.documentElement,t=" w-mod-";n.className+=t+"js",("ontouchstart"in o||o.DocumentTouch&&c instanceof DocumentTouch)&&(n.className+=t+"touch")}(window,document);
    </script>

    <!-- Load Theme JS for AJAX cart drawer -->
    <script src="{{ 'theme.js' | asset_url }}" defer="defer"></script>

    {{ content_for_header }}

    <!-- Expose Theme Customizer Variable Settings -->
    {%- style -%}
      :root {
        --color-bg: {{ settings.color_bg }};
        --color-text: {{ settings.color_text }};
        --color-text-muted: {{ settings.color_text_muted }};
        --color-primary: {{ settings.color_primary }};
        --color-secondary: {{ settings.color_secondary }};
        --color-border: {{ settings.color_border }};
        --color-card-bg: {{ settings.color_card_bg }};
        --color-btn-bg: {{ settings.color_btn_bg }};
        --color-btn-text: {{ settings.color_btn_text }};
      }
    {%- endstyle -%}

    <!-- Load Verbatim Webflow Export CSS -->
    {{ 'commercetemplate.css' | asset_url | stylesheet_tag }}
    
    <!-- Load Theme CSS for cart drawer overlays -->
    {{ 'theme.css' | asset_url | stylesheet_tag }}

    <script>document.documentElement.className = document.documentElement.className.replace('no-js', 'js');</script>
  </head>

  <body class="template-{{ template.name }}">
    <a class="skip-to-content-link button visually-hidden" href="#MainContent">
      Skip to content
    </a>

    <!-- Webflow Root Page Wrapper -->
    <div class="page-wrapper">
      {% section 'header' %}

      <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
        {{ content_for_layout }}
      </main>

      {% section 'footer' %}
    </div>

    {%- if settings.enable_cart_drawer -%}
      {% render 'cart-drawer' %}
    {%- endif -%}

    <script>
      window.shopUrl = '{{ request.origin }}';
      window.routes = {
        cart_add_url: '{{ routes.cart_add_url }}',
        cart_change_url: '{{ routes.cart_change_url }}',
        cart_update_url: '{{ routes.cart_update_url }}',
        cart_url: '{{ routes.cart_url }}'
      };
      window.cartStrings = {
        error: `There was an error adding this item`
      };
    </script>
    
    <!-- Load jQuery & Webflow runtime synchronously at the bottom to bind interactions properly -->
    <script src="{{ 'jquery.min.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'webflow.js' | asset_url }}" defer="defer"></script>
  </body>
</html>
